{
  "manifest_version": 3,
  "name": "Localizar mi móvil",
  "version": "1.0.0",
  "description": "Un clic para abrir Find My Device (Android) o Find My iPhone y hacer sonar tu teléfono cuando no lo encuentras.",
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Localizar mi móvil",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
